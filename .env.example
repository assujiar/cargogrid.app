# CargoGrid — example environment variables (local development)
# Copy to .env.local and fill in values from `supabase start` output (never commit .env.local).
#
# Production-link safeguard: scripts/preflight-env-check.ts rejects any SUPABASE_URL that does not
# point at a local/loopback address unless ALLOW_NON_LOCAL_SUPABASE_URL=true is explicitly set —
# never point a local dev environment at a real tenant's production project.

# --- Supabase local stack (values printed by `supabase start`) ---
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key-from-supabase-start
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key-from-supabase-start
# ^ SERVICE_ROLE_KEY is server-only per AGENTS.md — never referenced from a Client Component,
#   never logged, never sent to the browser bundle.

# --- App ---
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
NODE_ENV=development

# --- Explicit opt-in only; do not set locally under normal circumstances ---
# ALLOW_NON_LOCAL_SUPABASE_URL=true
