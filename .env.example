# CargoGrid — example environment variables (local development)
# Copy to .env.local and fill in values from `supabase start` output (never commit .env.local).
#
# Every variable here is declared and typed in scripts/env/schema.ts — that file, not this one, is
# the source of truth. `pnpm run preflight` (scripts/env/validate.ts) validates all of them at
# startup and rejects a NEXT_PUBLIC_SUPABASE_URL whose loopback-ness doesn't match CARGOGRID_ENV
# (local must be loopback; every other tier must NOT be — docs/architecture/11_*.md section 2) — never
# point a local dev environment at a real tenant's production project.

# --- Environment class (one of: local, development, testing, staging, uat, production, sandbox) ---
CARGOGRID_ENV=local
NODE_ENV=development

# --- Supabase local stack (values printed by `supabase start`) ---
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key-from-supabase-start
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key-from-supabase-start
# ^ SERVICE_ROLE_KEY is server-only per AGENTS.md — never referenced from a Client Component,
#   never logged, never sent to the browser bundle.

# --- App ---
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
